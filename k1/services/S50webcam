#!/bin/sh

PID_FILE="/var/run/webcam.pid"

# max fps for the camera
FRAMES_PER_SECOND=10

case "$1" in
  start)
    V4L_DEVICE=$(v4l2-ctl --list-devices|grep -A1 usb|sed 's/^[[:space:]]*//g'|grep '^/dev' | head -1)
    if [ "x$V4L_DEVICE" = "x" ]; then
      echo "WARNING: No webcams found!"
      exit 1
    fi

    start-stop-daemon -S -b -m -p $PID_FILE --exec /usr/data/ustreamer/ustreamer -- -n -r 1280x720 -c HW -m MJPEG -b 1 -w 1 -f $FRAMES_PER_SECOND -l -d $V4L_DEVICE --host=0.0.0.0 --allow-origin=*  --device-timeout 15
    ;;
  stop)
    start-stop-daemon -K -p $PID_FILE > /dev/null 2>&1
    ;;

  restart|reload)
    "$0" stop
    "$0" start
    ;;
  *)
    echo "Usage:"
    echo "    $0 {start|stop|restart}"
    exit 1
esac

exit $?
