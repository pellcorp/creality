# https://www.printables.com/model/965667-wip-k1-btt-eddy-rear-mount-v4

-- eddyng.cfg
[probe_eddy_ng btt_eddy]
x_offset: 0.0
y_offset: 24.82

[bed_mesh]
mesh_min: 10,30
mesh_max: 280,280

[screws_tilt_adjust]
screw1: 42,23
screw2: 301,23
screw3: 271,272
screw4: 71,272

[axis_twist_compensation]
calibrate_start_x: 10
calibrate_end_x: 280
calibrate_y: 153

-- printer.cfg
[stepper_y]
position_max: 290
