# https://www.printables.com/model/1037606-cartographer-3d-right-angle-k1-series-mount

-- cartotouch.cfg
[scanner]
x_offset: -16.0
y_offset: 0.0

[bed_mesh]
mesh_min: 5,10
mesh_max: 215,215

[screws_tilt_adjust]
__action__: DELETED

[axis_twist_compensation]
calibrate_start_x: 30
calibrate_end_x: 210
calibrate_y: 105
