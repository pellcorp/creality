# https://www.printables.com/model/1002777-cr-touch-to-btt-eddy-adapter-bracket

-- btteddy.cfg
[probe_eddy_current btt_eddy]
x_offset: 0.0
y_offset: 27.0

[bed_mesh]
mesh_min: 5,10
mesh_max: 215,215

[screws_tilt_adjust]
screw1: 27.5, -0.5
screw2: 196.5, -0.5
screw3: 196.5, 169.5
screw4: 27.5, 169.5

[axis_twist_compensation]
calibrate_start_x: 30
calibrate_end_x: 192
calibrate_y: 105
